# Google AI Studio key — required for Gemini-powered drafting/extraction.
# Get one (free, no card) at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Langfuse Cloud (optional but recommended for tracing every LLM call).
# Sign up at https://cloud.langfuse.com — Hobby tier is free.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Qdrant — defaults to the local docker-compose service.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Caches and optional providers.
DOCLING_CACHE_DIR=./cache/docling
HF_TOKEN=

# Behaviour toggles.
TITAN_LOCAL_MODELS=0     # 1 = enable local BGE reranker / sentence-transformers
TITAN_LOG_LEVEL=INFO     # DEBUG/INFO/WARNING/ERROR
TITAN_LOG_JSON=0         # 1 = JSON-formatted structlog (machine-readable)
