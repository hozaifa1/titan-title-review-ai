# ── Primary LLM (Gemini) ────────────────────────────────────────────────────
# Google AI Studio key (free, no card). Use with Gemini 2.0 Flash.
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Optional second Gemini key — auto-fallback when the primary 429s.
GOOGLE_API_KEY_FALLBACK=
GEMINI_MODEL=gemini-2.0-flash

# ── Alternative providers (used as fallback when primary is rate-limited) ──
# Order is configured via TITAN_LLM_PROVIDER_ORDER below. Per-provider keys
# are optional individually — the client skips any provider whose key is
# absent or whose model id 4xxs at request time.

# Cerebras — 60K tokens/min free, ~1,700 req/day, FASTEST on the market
# (1000+ TPS). No credit card. https://cloud.cerebras.ai/  →  API Keys
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# SambaNova — Llama 3.3 70B + DeepSeek R1, fast free tier.
# https://cloud.sambanova.ai/  →  API
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

# Groq — Llama 3.3 70B, ~14,400 req/day free, ~30 req/min.
# https://console.groq.com
GROQ_API_KEY=
# Models: llama-3.3-70b-versatile (best), llama-3.1-8b-instant (cheap),
#         mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# GitHub Models — free for any GitHub PAT with `models:read` scope.
# https://github.com/settings/tokens?type=beta  (Fine-grained, Models: Read)
GITHUB_MODELS_TOKEN=
# Model id is the bare catalog entry (no vendor prefix).
GITHUB_MODELS_MODEL=Llama-3.3-70B-Instruct

# OpenRouter — single key, dozens of free models. https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Pick a `:free` variant that's currently available.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── LLM-client behaviour ───────────────────────────────────────────────────
# Provider order — chain walked left→right. First with quota+working keys
# wins; subsequent providers are tried on 429/timeout/permanent-error.
TITAN_LLM_PROVIDER_ORDER=github,cerebras,sambanova,groq,gemini,openrouter
# Global concurrency cap across all providers. 12 is safe with per-provider
# locks; drop to 3 if you see burst-429 storms on a flaky free tier.
TITAN_LLM_MAX_CONCURRENCY=12
# Per-call timeout (seconds). Stalls beyond this mark the provider dead
# so they don't drain the executor pool.
TITAN_LLM_PER_CALL_TIMEOUT=15
# Total budget across the full chain walk for one logical call.
TITAN_LLM_TOTAL_TIMEOUT=120
# Disk-backed response cache. Eval reruns become near-free.
TITAN_LLM_CACHE=1

# ── Observability ──────────────────────────────────────────────────────────
# Langfuse Cloud (optional but recommended for tracing every LLM call).
# Sign up at https://cloud.langfuse.com — Hobby tier is free.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Vector store ───────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Caches and optional providers ──────────────────────────────────────────
DOCLING_CACHE_DIR=./cache/docling
HF_TOKEN=

# ── Behaviour toggles ──────────────────────────────────────────────────────
TITAN_LOCAL_MODELS=0     # 1 = enable local BGE reranker / sentence-transformers
TITAN_LOG_LEVEL=INFO     # DEBUG/INFO/WARNING/ERROR
TITAN_LOG_JSON=0         # 1 = JSON-formatted structlog (machine-readable)
